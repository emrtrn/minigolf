{
  "schema": 1,
  "type": "ui",
  "name": "Menu",
  "preview": {
    "width": 1280,
    "height": 720
  },
  "theme": "default-theme",
  "transition": {
    "enter": "scale",
    "exit": "scale",
    "durationMs": 160
  },
  "root": {
    "id": "root",
    "widget": "Canvas",
    "props": {
      "align": "center",
      "justify": "center"
    },
    "children": [
      {
        "id": "image-1",
        "widget": "Image",
        "props": {
          "width": 200,
          "height": 50
        },
        "children": []
      },
      {
        "id": "panel",
        "widget": "Stack",
        "props": {
          "direction": "column",
          "gap": 18,
          "align": "center",
          "padding": 20,
          "background": "$color.surface",
          "radius": 8
        },
        "children": [
          {
            "id": "title",
            "widget": "Text",
            "props": {
              "text": "Paused",
              "fontSize": 40,
              "fontWeight": 700,
              "color": "$color.text"
            },
            "children": []
          },
          {
            "id": "subtitle",
            "widget": "Text",
            "props": {
              "text": "Forge — UMG Lite",
              "fontSize": 16,
              "color": "$color.muted"
            },
            "children": []
          },
          {
            "id": "resume",
            "widget": "Button",
            "props": {
              "text": "Resume",
              "onClick": {
                "type": "back"
              }
            },
            "children": []
          },
          {
            "id": "options",
            "widget": "Button",
            "props": {
              "text": "Options",
              "onClick": {
                "type": "message",
                "message": "Menu.OpenOptions"
              }
            },
            "children": []
          }
        ]
      }
    ]
  }
}
