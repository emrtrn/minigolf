{
  "schema": 1,
  "name": "minigolf",
  "type": "three-game",
  "version": "0.1.0",
  "entry": "src/main.ts",
  "publicDir": "public",
  "editor": {
    "defaultScene": "assets/minigolf/levels/mini-golf-hole-01.level.json",
    "assetManifest": "assets/manifest.json",
    "gridSize": 1,
